{"id": "ja-hyakunin-001", "title": "百人一首 第1番", "author": "天智天皇", "language": "ja", "era": "平安〜鎌倉", "full_text": "秋の田の\nかりほの庵の\n苫をあらみ\n我が衣手は\n露にぬれつつ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-002", "title": "百人一首 第2番", "author": "持統天皇", "language": "ja", "era": "平安〜鎌倉", "full_text": "春過ぎて\n夏来にけらし\n白妙の\n衣ほすてふ\n天の香具山", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-003", "title": "百人一首 第3番", "author": "柿本人麻呂", "language": "ja", "era": "平安〜鎌倉", "full_text": "あしびきの\n山鳥の尾の\nしだり尾の\nながながし夜を\nひとりかも寝む", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-004", "title": "百人一首 第4番", "author": "山部赤人", "language": "ja", "era": "平安〜鎌倉", "full_text": "田子の浦に\nうちいでてみれば\n白妙の\n富士の高嶺に\n雪は降りつつ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-005", "title": "百人一首 第5番", "author": "猿丸太夫", "language": "ja", "era": "平安〜鎌倉", "full_text": "奥山に\nもみぢふみわけ\nなく鹿の\n声聞く時ぞ\n秋はかなしき", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-006", "title": "百人一首 第6番", "author": "中納言家持", "language": "ja", "era": "平安〜鎌倉", "full_text": "かささぎの\n渡せる橋に\nおく霜の\n白きをみれば\n夜ぞふけにける", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-007", "title": "百人一首 第7番", "author": "阿倍仲麻呂", "language": "ja", "era": "平安〜鎌倉", "full_text": "天の原\nふりさけみれば\n春日なる\n三笠の山に\nいでし月かも", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-008", "title": "百人一首 第8番", "author": "喜撰法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "わが庵は\n都のたつみ\nしかぞすむ\n世をうぢ山と\n人はいふなり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-009", "title": "百人一首 第9番", "author": "小野小町", "language": "ja", "era": "平安〜鎌倉", "full_text": "花の色は\nうつりにけりな\nいたづらに\nわが身よにふる\nながめせしまに", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-010", "title": "百人一首 第10番", "author": "蝉丸", "language": "ja", "era": "平安〜鎌倉", "full_text": "これやこの\n行くも帰るも\nわかれては\nしるもしらぬも\n逢坂の関", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-011", "title": "百人一首 第11番", "author": "参議篁", "language": "ja", "era": "平安〜鎌倉", "full_text": "わたの原\n八十島かけて\nこぎいでぬと\n人にはつげよ\nあまのつり舟", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-012", "title": "百人一首 第12番", "author": "僧正遍昭", "language": "ja", "era": "平安〜鎌倉", "full_text": "天つ風\n雲のかよひ路\n吹きとぢよ\nをとめの姿\nしばしとどめむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-013", "title": "百人一首 第13番", "author": "陽成院", "language": "ja", "era": "平安〜鎌倉", "full_text": "つくばねの\n峰よりおつる\nみなの川\n恋ぞつもりて\n淵となりぬる", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-014", "title": "百人一首 第14番", "author": "河原左大臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "みちのくの\nしのぶもぢずり\n誰ゆゑに\nみだれそめにし\n我ならなくに", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-015", "title": "百人一首 第15番", "author": "光孝天皇", "language": "ja", "era": "平安〜鎌倉", "full_text": "君がため\n春の野に出でて\n若菜つむ\nわが衣手に\n雪はふりつつ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-016", "title": "百人一首 第16番", "author": "中納言行平", "language": "ja", "era": "平安〜鎌倉", "full_text": "立ちわかれ\nいなばの山の\n峰に生ふる\nまつとし聞かば\nいまかへりこむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-017", "title": "百人一首 第17番", "author": "在原業平朝臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "ちはやぶる\n神代もきかず\n竜田川\nからくれなゐに\n水くくるとは", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-018", "title": "百人一首 第18番", "author": "藤原敏行", "language": "ja", "era": "平安〜鎌倉", "full_text": "住の江の\n岸による波\nよるさへや\n夢のかよひ路\n人目よくらむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-019", "title": "百人一首 第19番", "author": "伊勢", "language": "ja", "era": "平安〜鎌倉", "full_text": "難波潟\nみじかき蘆の\nふしのまも\nあはでこの世を\nすぐしてよとや", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-020", "title": "百人一首 第20番", "author": "元良親王", "language": "ja", "era": "平安〜鎌倉", "full_text": "わびぬれば\nいまはたおなじ\n難波なる\n身をつくしても\nあはむとぞ思ふ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-021", "title": "百人一首 第21番", "author": "素性法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "今こむと\nいひしばかりに\n長月の\n有明の月を\nまちいでつるかな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-022", "title": "百人一首 第22番", "author": "文屋康秀", "language": "ja", "era": "平安〜鎌倉", "full_text": "吹くからに\n秋の草木の\nしをるれば\nむべ山風を\n嵐といふらむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-023", "title": "百人一首 第23番", "author": "大江千里", "language": "ja", "era": "平安〜鎌倉", "full_text": "月みれば\nちぢにものこそ\nかなしけれ\nわが身一つの\n秋にはあらねど", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-024", "title": "百人一首 第24番", "author": "菅家", "language": "ja", "era": "平安〜鎌倉", "full_text": "このたびは\nぬさもとりあへず\n手向山\nもみぢのにしき\n神のまにまに", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-025", "title": "百人一首 第25番", "author": "三条右大臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "名にし負はば\n逢坂山の\nさねかづら\n人にしられで\n来るよしもがな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-026", "title": "百人一首 第26番", "author": "貞信公", "language": "ja", "era": "平安〜鎌倉", "full_text": "小倉山\n峰のもみぢ葉\n心あらば\nいまひとたびの\nみゆきまたなむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-027", "title": "百人一首 第27番", "author": "中納言兼輔", "language": "ja", "era": "平安〜鎌倉", "full_text": "みかの原\nわきて流るる\nいづみ川\nいつみきとてか\n恋しかるらむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-028", "title": "百人一首 第28番", "author": "源宗行朝臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "山里は\n冬ぞさびしさ\nまさりける\n人目も草も\nかれぬと思へば", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-029", "title": "百人一首 第29番", "author": "凡河内躬恒", "language": "ja", "era": "平安〜鎌倉", "full_text": "心当てに\n折らばや折らむ\n初霜の\nおきまどはせる\n白菊の花", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-030", "title": "百人一首 第30番", "author": "壬生忠岑", "language": "ja", "era": "平安〜鎌倉", "full_text": "有明の\nつれなく見えし\n別れより\nあかつきばかり\nうきものはなし", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-031", "title": "百人一首 第31番", "author": "坂上是則", "language": "ja", "era": "平安〜鎌倉", "full_text": "朝ぼらけ\n有明の月と\n見るまでに\n吉野の里に\n降れる白雪", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-032", "title": "百人一首 第32番", "author": "春道列樹", "language": "ja", "era": "平安〜鎌倉", "full_text": "山川に\n風のかけたる\nしがらみは\nながれもあへぬ\nもみぢなりけり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-033", "title": "百人一首 第33番", "author": "紀友則", "language": "ja", "era": "平安〜鎌倉", "full_text": "久方の\n光のどけき\n春の日に\nしづ心なく\n花の散るらむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-034", "title": "百人一首 第34番", "author": "藤原興風", "language": "ja", "era": "平安〜鎌倉", "full_text": "誰をかも\nしる人にせむ\n高砂の\n松も昔の\n友ならなくに", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-035", "title": "百人一首 第35番", "author": "紀貫之", "language": "ja", "era": "平安〜鎌倉", "full_text": "人はいさ\n心も知らず\nふるさとは\n花ぞ昔の\n香に匂ひける", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-036", "title": "百人一首 第36番", "author": "清原深養父", "language": "ja", "era": "平安〜鎌倉", "full_text": "夏の夜は\nまだ宵ながら\nあけぬるを\n雲のいづこに\n月やどるらむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-037", "title": "百人一首 第37番", "author": "文屋朝康", "language": "ja", "era": "平安〜鎌倉", "full_text": "白露に\n風の吹きしく\n秋の野は\nつらぬきとめぬ\n玉ぞ散りける", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-038", "title": "百人一首 第38番", "author": "右近", "language": "ja", "era": "平安〜鎌倉", "full_text": "忘らるる\n身をば思はず\nちかひてし\n人の命の\n惜しくもあるかな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-039", "title": "百人一首 第39番", "author": "参議等", "language": "ja", "era": "平安〜鎌倉", "full_text": "浅茅生の\n小野の篠原\nしのぶれど\nあまりてなどか\n人の恋しき", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-040", "title": "百人一首 第40番", "author": "平兼盛", "language": "ja", "era": "平安〜鎌倉", "full_text": "しのぶれど\n色に出でにけり\n我が恋は\n物や思ふと\n人の問ふまで", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-041", "title": "百人一首 第41番", "author": "壬生忠見", "language": "ja", "era": "平安〜鎌倉", "full_text": "恋すてふ\n我が名はまだき\n立ちにけり\n人しれずこそ\n思ひそめしか", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-042", "title": "百人一首 第42番", "author": "清原元輔", "language": "ja", "era": "平安〜鎌倉", "full_text": "ちぎりきな\nかたみに袖を\nしぼりつつ\n末の松山\n波こさじとは", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-043", "title": "百人一首 第43番", "author": "権中納言敦忠", "language": "ja", "era": "平安〜鎌倉", "full_text": "あひみての\nのちの心に\nくらぶれば\n昔は物を\n思はざりけり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-044", "title": "百人一首 第44番", "author": "中納言朝忠", "language": "ja", "era": "平安〜鎌倉", "full_text": "あふことの\nたえてしなくば\nなかなかに\n人をも身をも\n恨みざらまし", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-045", "title": "百人一首 第45番", "author": "謙徳公", "language": "ja", "era": "平安〜鎌倉", "full_text": "あはれとも\nいふべき人は\n思ほえで\n身のいたづらに\nなりぬべきかな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-046", "title": "百人一首 第46番", "author": "曽禰好忠", "language": "ja", "era": "平安〜鎌倉", "full_text": "由良のとを\n渡る舟人\nかぢをたえ\nゆくへも知らぬ\n恋の道かな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-047", "title": "百人一首 第47番", "author": "恵慶法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "八重むぐら\nしげれる宿の\nさびしきに\n人こそ見えね\n秋は来にけり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-048", "title": "百人一首 第48番", "author": "源重之", "language": "ja", "era": "平安〜鎌倉", "full_text": "風をいたみ\n岩うつ波の\nおのれのみ\nくだけて物を\n思ふころかな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-049", "title": "百人一首 第49番", "author": "大中臣能宣朝臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "みかきもり\n衛士のたく火の\n夜はもえ\n昼は消えつつ\n物をこそ思へ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-050", "title": "百人一首 第50番", "author": "藤原義孝", "language": "ja", "era": "平安〜鎌倉", "full_text": "君がため\n惜しからざりし\nいのちさへ\n長くもがなと\n思ひけるかな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-051", "title": "百人一首 第51番", "author": "藤原実方朝臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "かくとだに\nえやはいぶきの\nさしも草\nさしもしらじな\nもゆる思ひを", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-052", "title": "百人一首 第52番", "author": "藤原道信朝臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "あけぬれば\n暮るるものとは\n知りながら\nなほうらめしき\n朝ぼらけかな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-053", "title": "百人一首 第53番", "author": "右大将道綱母", "language": "ja", "era": "平安〜鎌倉", "full_text": "なげきつつ\nひとりぬる夜の\nあくるまは\nいかに久しき\nものとかはしる", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-054", "title": "百人一首 第54番", "author": "儀同三司母", "language": "ja", "era": "平安〜鎌倉", "full_text": "忘れじの\nゆく末までは\nかたければ\n今日をかぎりの\nいのちともがな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-055", "title": "百人一首 第55番", "author": "大納言公任", "language": "ja", "era": "平安〜鎌倉", "full_text": "滝の音は\nたえて久しく\nなりぬれど\n名こそ流れて\nなほ聞こえけれ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-056", "title": "百人一首 第56番", "author": "和泉式部", "language": "ja", "era": "平安〜鎌倉", "full_text": "あらざらむ\nこの世のほかの\n思ひ出に\nいまひとたびの\nあふこともがな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-057", "title": "百人一首 第57番", "author": "紫式部", "language": "ja", "era": "平安〜鎌倉", "full_text": "めぐりあひて\n見しやそれとも\nわかぬまに\n雲がくれにし\n夜半の月かな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-058", "title": "百人一首 第58番", "author": "大弐三位", "language": "ja", "era": "平安〜鎌倉", "full_text": "ありま山\nゐなの笹原\n風吹けば\nいでそよ人を\n忘れやはする", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-059", "title": "百人一首 第59番", "author": "赤染衛門", "language": "ja", "era": "平安〜鎌倉", "full_text": "やすらはで\n寝なましものを\nさ夜ふけて\nかたぶくまでの\n月を見しかな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-060", "title": "百人一首 第60番", "author": "小式部内侍", "language": "ja", "era": "平安〜鎌倉", "full_text": "大江山\nいく野の道の\n遠ければ\nまだふみもみず\n天の橋立", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-061", "title": "百人一首 第61番", "author": "伊勢大輔", "language": "ja", "era": "平安〜鎌倉", "full_text": "いにしへの\n奈良の都の\n八重桜\nけふ九重に\n匂ひぬるかな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-062", "title": "百人一首 第62番", "author": "清少納言", "language": "ja", "era": "平安〜鎌倉", "full_text": "夜をこめて\n鳥のそらねは\nはかるとも\nよに逢坂の\n関はゆるさじ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-063", "title": "百人一首 第63番", "author": "左京大夫道雅", "language": "ja", "era": "平安〜鎌倉", "full_text": "いまはただ\n思ひ絶えなむ\nとばかりを\n人づてならで\n言ふよしもがな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-064", "title": "百人一首 第64番", "author": "権中納言定頼", "language": "ja", "era": "平安〜鎌倉", "full_text": "朝ぼらけ\n宇治の川霧\n絶え絶えに\nあらはれわたる\n瀬々の網代木", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-065", "title": "百人一首 第65番", "author": "相模", "language": "ja", "era": "平安〜鎌倉", "full_text": "うらみわび\nほさぬ袖だに\nあるものを\n恋にくちなむ\n名こそをしけれ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-066", "title": "百人一首 第66番", "author": "前大僧正行尊", "language": "ja", "era": "平安〜鎌倉", "full_text": "もろともに\nあはれと思へ\n山桜\n花よりほかに\n知る人もなし", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-067", "title": "百人一首 第67番", "author": "周防内侍", "language": "ja", "era": "平安〜鎌倉", "full_text": "春の夜の\n夢ばかりなる\n手枕に\nかひなくたたむ\n名こそをしけれ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-068", "title": "百人一首 第68番", "author": "三条院", "language": "ja", "era": "平安〜鎌倉", "full_text": "心にも\nあらでうき世に\nながらへば\n恋しかるべき\n夜半の月かな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-069", "title": "百人一首 第69番", "author": "能因法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "あらし吹く\nみ室の山の\nもみぢばは\n竜田の川の\n錦なりけり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-070", "title": "百人一首 第70番", "author": "良選法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "さびしさに\n宿を立ち出でて\nながむれば\nいづくもおなじ\n秋の夕ぐれ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-071", "title": "百人一首 第71番", "author": "大納言経信", "language": "ja", "era": "平安〜鎌倉", "full_text": "夕されば\n門田の稲葉\nおとづれて\n蘆のまろやに\n秋風ぞ吹く", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-072", "title": "百人一首 第72番", "author": "祐子内親王家紀伊", "language": "ja", "era": "平安〜鎌倉", "full_text": "音に聞く\n高師の浜の\nあだ波は\nかけじや袖の\nぬれもこそすれ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-073", "title": "百人一首 第73番", "author": "前権中納言匡房", "language": "ja", "era": "平安〜鎌倉", "full_text": "高砂の\nをのへのさくら\nさきにけり\nとやまのかすみ\nたたずもあらなむ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-074", "title": "百人一首 第74番", "author": "源俊頼朝臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "憂かりける\n人を初瀬の\n山おろしよ\nはげしかれとは\n祈らぬものを", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-075", "title": "百人一首 第75番", "author": "藤原基俊", "language": "ja", "era": "平安〜鎌倉", "full_text": "ちぎりおきし\nさせもが露を\nいのちにて\nあはれ今年の\n秋もいぬめり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-076", "title": "百人一首 第76番", "author": "法性寺入道前関白太政大臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "わたの原\nこぎいでてみれば\n久方の\n雲ゐにまがふ\n沖つ白波", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-077", "title": "百人一首 第77番", "author": "崇徳院", "language": "ja", "era": "平安〜鎌倉", "full_text": "瀬をはやみ\n岩にせかるる\n滝川の\nわれても末に\nあはむとぞ思ふ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-078", "title": "百人一首 第78番", "author": "源兼昌", "language": "ja", "era": "平安〜鎌倉", "full_text": "淡路島\nかよふ千鳥の\n鳴く声に\n幾夜ねざめぬ\n須磨の関守", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-079", "title": "百人一首 第79番", "author": "左京大夫顕輔", "language": "ja", "era": "平安〜鎌倉", "full_text": "秋風に\nたなびく雲の\nたえ間より\nもれいづる月の\n影のさやけさ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-080", "title": "百人一首 第80番", "author": "待賢門院堀河", "language": "ja", "era": "平安〜鎌倉", "full_text": "長からむ\n心もしらず\n黒髪の\nみだれてけさは\n物をこそ思へ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-081", "title": "百人一首 第81番", "author": "後徳大寺左大臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "ほととぎす\n鳴きつる方を\nながむれば\nただありあけの\n月ぞ残れる", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-082", "title": "百人一首 第82番", "author": "道因法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "思ひわび\nさてもいのちは\nあるものを\n憂きにたへぬは\n涙なりけり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-083", "title": "百人一首 第83番", "author": "皇太后宮大夫俊成", "language": "ja", "era": "平安〜鎌倉", "full_text": "世の中よ\n道こそなけれ\n思ひ入る\n山の奥にも\n鹿ぞ鳴くなる", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-084", "title": "百人一首 第84番", "author": "藤原清輔朝臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "ながらへば\nまたこのごろや\nしのばれむ\n憂しと見し世ぞ\n今は恋しき", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-085", "title": "百人一首 第85番", "author": "俊恵法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "夜もすがら\n物思ふころは\n明けやらで\n閨のひまさへ\nつれなかりけり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-086", "title": "百人一首 第86番", "author": "西行法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "なげけとて\n月やは物を\n思はする\nかこち顔なる\nわが涙かな", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-087", "title": "百人一首 第87番", "author": "寂蓮法師", "language": "ja", "era": "平安〜鎌倉", "full_text": "村雨の\n露もまだひぬ\nまきの葉に\n霧たちのぼる\n秋の夕ぐれ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-088", "title": "百人一首 第88番", "author": "皇嘉門院別当", "language": "ja", "era": "平安〜鎌倉", "full_text": "難波江の\n蘆のかりねの\nひとよゆゑ\nみをつくしてや\n恋ひわたるべき", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-089", "title": "百人一首 第89番", "author": "式子内親王", "language": "ja", "era": "平安〜鎌倉", "full_text": "玉の緒よ\nたえなばたえね\nながらへば\n忍ぶることの\n弱りもぞする", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-090", "title": "百人一首 第90番", "author": "殷富門院大輔", "language": "ja", "era": "平安〜鎌倉", "full_text": "見せばやな\n雄島のあまの\n袖だにも\nぬれにぞぬれし\n色はかはらず", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-091", "title": "百人一首 第91番", "author": "後京極摂政前太政大臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "きりぎりす\n鳴くや霜夜の\nさむしろに\n衣かたしき\nひとりかも寝む", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-092", "title": "百人一首 第92番", "author": "二条院讃岐", "language": "ja", "era": "平安〜鎌倉", "full_text": "わが袖は\n潮干にみえぬ\n沖の石の\n人こそしらね\nかわくまもなし", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-093", "title": "百人一首 第93番", "author": "鎌倉右大臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "世の中は\nつねにもがもな\nなぎさこぐ\nあまの小舟の\n綱手かなしも", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-094", "title": "百人一首 第94番", "author": "参議雅経", "language": "ja", "era": "平安〜鎌倉", "full_text": "み吉野の\n山の秋風\nさ夜ふけて\nふるさと寒く\n衣うつなり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-095", "title": "百人一首 第95番", "author": "前大僧正慈円", "language": "ja", "era": "平安〜鎌倉", "full_text": "おほけなく\nうき世の民に\nおほふかな\nわがたつ杣に\n墨染の袖", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-096", "title": "百人一首 第96番", "author": "入道前太政大臣", "language": "ja", "era": "平安〜鎌倉", "full_text": "花さそふ\n嵐の庭の\n雪ならで\nふりゆくものは\nわが身なりけり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-097", "title": "百人一首 第97番", "author": "権中納言定家", "language": "ja", "era": "平安〜鎌倉", "full_text": "こぬ人を\nまつほの浦の\n夕なぎに\n焼くやもしほの\n身もこがれつつ", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-098", "title": "百人一首 第98番", "author": "従二位家隆", "language": "ja", "era": "平安〜鎌倉", "full_text": "風そよぐ\nならの小川の\n夕ぐれは\nみそぎぞ夏の\nしるしなりける", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-099", "title": "百人一首 第99番", "author": "後鳥羽院", "language": "ja", "era": "平安〜鎌倉", "full_text": "人もをし\n人もうらめし\nあぢきなく\n世を思ふゆゑに\n物思ふ身は", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
{"id": "ja-hyakunin-100", "title": "百人一首 第100番", "author": "順徳院", "language": "ja", "era": "平安〜鎌倉", "full_text": "ももしきや\nふるき軒ばの\nしのぶにも\nなほあまりある\n昔なりけり", "source_name": "小倉百人一首 (tomari/ogura-hyakunin-isshu)", "source_url": "https://raw.githubusercontent.com/tomari/ogura-hyakunin-isshu/master/hyakunin.json", "license": "Public Domain (13th-century anthology)"}
