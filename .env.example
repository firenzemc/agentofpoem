# Copy to .env and fill in. The .env file is gitignored.

# DeepSeek official API (OpenAI-compatible). Get a key at https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
# Cheap swarm model. Official API exposes: deepseek-v4-flash, deepseek-v4-pro
DEEPSEEK_MODEL=deepseek-v4-flash

# Swarm tuning. Smaller batch = more agents (more visible swarm, slightly higher cost).
SWARM_BATCH_SIZE=4
SWARM_CONCURRENCY=48

# Corpus
POEMS_PATH=data
# Hard bound on agents per query; batch grows to fit. Concurrency hard-capped at 64 in code.
SWARM_MAX_AGENTS=128
# Two-stage swarm: scouts scan digests (cheap), judges read shortlisted full texts.
SWARM_SCOUT_BATCH=80
SWARM_SHORTLIST=240

# Funnel retrieval. vector = embedding pre-filter (needs EMBED_* + data/embeddings.npz);
# scout = fallback LLM digest scan (no embeddings needed).
RETRIEVAL_MODE=hybrid
# OpenAI-compatible embeddings endpoint. Cohere embed v4 (embed-v-4-0) needs array input.
EMBED_BASE_URL=https://aihubmix.com/v1
EMBED_API_KEY=
EMBED_MODEL=embed-v-4-0
VEC_TOPK=80
TRIM_TOPN=30
EXPERT_BATCH=8

# Swarm model provider: deepseek (default) | glm. GLM free tier may be rate-limited.
SWARM_PROVIDER=deepseek
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
GLM_API_KEY=
GLM_MODEL=glm-4.7-flash
# RETRIEVAL_MODE: hybrid | image | line | scout  (per-query override: /api/search?retrieval=)
